# ============================================================
# Project Echo — 环境变量模板
# 使用方式: cp .env.example .env 然后根据实际情况修改
# ============================================================

# ─────────────────────────────────────────────
# Docker 镜像加速（国内拉取 docker.io 失败时设置）
# 示例: docker.m.daocloud.io/  或  mirror.ccs.tencentyun.com/library/（视镜像站而定）
# 留空则直连 Docker Hub
# ─────────────────────────────────────────────
# 适用于 redis / neo4j / minio 等 compose 中 image: 字段
DOCKER_REGISTRY_PREFIX=

# 构建阶段基础镜像前缀（temurin / python），建议留空直连 Docker Hub
# daocloud 等镜像站对 eclipse-temurin 常返回 401，勿与 DOCKER_REGISTRY_PREFIX 混用
DOCKER_BUILD_REGISTRY_PREFIX=

# ─────────────────────────────────────────────
# Redis 配置 — 任务队列 & 会话缓存
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis 密码（默认为空，生产环境建议设置）
REDIS_PASSWORD=

# Redis 队列名称
REDIS_QUEUE_TRANSCRIBE=echo:queue:transcribe
REDIS_QUEUE_SUMMARIZE=echo:queue:summarize
REDIS_QUEUE_EMBED=echo:queue:embed

# ─────────────────────────────────────────────
# Neo4j 配置 — 知识图谱数据库
# ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=echo_neo4j_pass

# ─────────────────────────────────────────────
# MinIO 配置 — 本地对象存储
# ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=echo_minio_admin
MINIO_SECRET_KEY=echo_minio_secret
MINIO_SECURE=false

# MinIO Bucket 名称
MINIO_BUCKET_RAW_AUDIO=raw-audio
MINIO_BUCKET_TRANSCRIPTIONS=transcriptions
MINIO_BUCKET_MEMORY_CARDS=memory-cards
MINIO_BUCKET_SNAPSHOTS=snapshots

# ─────────────────────────────────────────────
# Ollama 配置 — 本地 LLM 推理（宿主机运行）
# ─────────────────────────────────────────────
# 本地 Ollama 服务地址（仅在本机/局域网内部使用）
OLLAMA_BASE_URL=http://localhost:11434
# 使用的 LLM 模型名称
OLLAMA_MODEL=qwen2.5:7b

# ─────────────────────────────────────────────
# WhisperX 配置 — 本地语音识别
# ─────────────────────────────────────────────
# 模型规格: tiny / base / small / medium / large-v2 / large-v3
WHISPER_MODEL=base
# 推理设备: cpu / cuda / mps
WHISPER_DEVICE=cpu
# 计算精度: float32 / float16 / int8
WHISPER_COMPUTE_TYPE=int8

# ─────────────────────────────────────────────
# 向量嵌入模型配置 — 本地 Sentence Transformers
# ─────────────────────────────────────────────
# 中文嵌入模型（自动从 HuggingFace 下载后本地缓存）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 向量维度（与模型匹配）
EMBEDDING_DIMENSION=512

# ─────────────────────────────────────────────
# Spring Boot 控制面配置（端口 8080）
# ─────────────────────────────────────────────
SERVER_PORT=8080
# JWT 签名密钥（生成方式: openssl rand -hex 32）
JWT_SECRET=change_me_to_a_256bit_random_secret_string_for_local_use
JWT_EXPIRATION_MS=86400000
# JWT 是否启用（生产环境建议 true）
JWT_ENABLED=false
# 用于换取 JWT 的 API Key（JWT_ENABLED=true 时必须设置）
# 生成方式: openssl rand -hex 32
ECHO_API_KEY=

# ─────────────────────────────────────────────
# FastAPI 数据面配置（端口 8001）
# ─────────────────────────────────────────────
DATA_PLANE_HOST=0.0.0.0
DATA_PLANE_PORT=8001
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# 模型缓存目录（挂载到容器内）
# ─────────────────────────────────────────────
MODEL_CACHE_DIR=~/.cache/huggingface

# ─────────────────────────────────────────────
# P2P 同步配置（设备间本地局域网同步，可选）
# ─────────────────────────────────────────────
P2P_ENABLED=false
# 本设备监听端口
P2P_PORT=9090
# 对端设备地址（逗号分隔，仅限局域网 IP）
P2P_PEERS=
# 设备身份密钥（用于 P2P 快照签名，生产环境必须修改）
# 生成方式: openssl rand -hex 32
P2P_DEVICE_SECRET=change_me_to_random_secret
# 设备名称（用于快照来源标识）
P2P_DEVICE_NAME=my-echo-device

# 控制面回调地址（数据面 Docker 容器访问控制面）
# Docker Compose 全栈部署: http://control-plane:8080
# 控制面在宿主机、数据面在容器: http://host.docker.internal:8080
CONTROL_PLANE_BASE_URL=http://localhost:8080

# 控制面访问数据面地址
# Docker Compose 全栈部署: http://data-plane:8001
# 本地开发（数据面在容器）: http://localhost:8001
DATA_PLANE_URL=http://localhost:8001

# ─────────────────────────────────────────────
# 音频加密配置（AES-256-GCM）
# ─────────────────────────────────────────────
# AES-256 加密密钥（Base64 编码的 32 字节，生产环境必须设置！）
# 生成方式: openssl rand -base64 32
# 注意: 此密钥一旦丢失，加密的音频将无法解密！请安全备份。
AUDIO_ENCRYPT_KEY=
